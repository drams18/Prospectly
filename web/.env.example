VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps JS SDK key for the location autocomplete widget only.
# Restrict it by HTTP referrer in the Google Cloud Console. This is NOT the
# server-side Places API key used by the Supabase Edge Function.
VITE_GOOGLE_MAPS_JS_KEY=your-browser-restricted-key
