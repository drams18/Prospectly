PORT=3001

# Google Maps Platform — activer: Geocoding API + Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# JWT secret — générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# Chemin vers la base SQLite (créé automatiquement)
DB_PATH=./data/prospectly.db
