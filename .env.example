# Google Maps Platform — activer: Geocoding API + Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optionnel — pour l'enrichissement web avancé (Custom Search API)
# Créer un moteur sur: https://programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=your_cse_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Rayon de recherche en mètres (défaut: 2000)
SEARCH_RADIUS=2000

# Nombre max de résultats à traiter (défaut: 60)
MAX_RESULTS=60

# Activer l'enrichissement CSE (true/false, défaut: false)
ENABLE_WEB_ENRICHMENT=false
